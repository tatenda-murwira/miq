{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30,
      "memory": 1024,
      "excludeFiles": "{backend/tests/**,backend/data/raw/**,backend/models/**,backend/reports/**,backend/.venv/**,**/__pycache__/**}"
    }
  }
}
